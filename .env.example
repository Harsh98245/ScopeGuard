# =============================================================================
# ScopeGuard — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# Never commit .env.local. Never log any value here.
# Format: KEY=value  # type | required/optional | description | example
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Public URL of the running app. Used in OAuth callbacks, email links, CSP.
# string | required | full origin including protocol | https://app.scopeguard.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public product name. Surfaced in emails and UI chrome.
# string | required | brand display name | ScopeGuard
NEXT_PUBLIC_APP_NAME=ScopeGuard

# Node environment. Next.js sets this automatically; override only for tests.
# enum(development|production|test) | optional | runtime mode | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase (Postgres + Auth + Storage + Realtime)
# -----------------------------------------------------------------------------

# Supabase project URL. Public — safe to expose to the client.
# string (URL) | required | from Supabase Dashboard → Settings → API | https://xyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key. Public — RLS enforces access.
# string (JWT) | required | Supabase Dashboard → Settings → API → anon key | eyJhbGc...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. SERVER-ONLY. Bypasses RLS — never expose.
# string (JWT) | required | Supabase Dashboard → Settings → API → service_role | eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string for Prisma migrations (uses pgbouncer-bypass port).
# string (URL) | required | Supabase Dashboard → Settings → Database → Connection string | postgresql://postgres:pass@db.xyz.supabase.co:5432/postgres
DATABASE_URL=

# Pooled connection string used at runtime (PgBouncer transaction mode).
# string (URL) | required | Supabase Dashboard → Settings → Database → Connection pooling | postgresql://postgres:pass@db.xyz.supabase.co:6543/postgres?pgbouncer=true
DATABASE_POOL_URL=

# -----------------------------------------------------------------------------
# Anthropic Claude API
# -----------------------------------------------------------------------------

# Anthropic API key for contract parsing and scope detection.
# string | required | console.anthropic.com → API Keys | sk-ant-api03-...
ANTHROPIC_API_KEY=

# Model ID used for parseContract / checkScope. See ADR-003.
# string | optional | defaults to claude-sonnet-4-6 | claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Postmark (inbound + outbound email)
# -----------------------------------------------------------------------------

# Postmark server token used to send transactional email.
# string (UUID) | required | Postmark → Server → API Tokens | abcdef12-3456-7890-abcd-...
POSTMARK_SERVER_TOKEN=

# Shared secret used to validate inbound webhook payloads.
# string | required | configured in Postmark Server → Inbound webhook URL | random 32+ char string
POSTMARK_WEBHOOK_SECRET=

# Domain attached to user inbound aliases (e.g. user-abc@inbound.scopeguard.app).
# string (domain) | required | must match Postmark inbound domain | inbound.scopeguard.app
INBOUND_EMAIL_DOMAIN=inbound.scopeguard.app

# From-address for outbound system emails.
# string (email) | required | must be a verified Postmark sender | hello@scopeguard.app
OUTBOUND_FROM_EMAIL=hello@scopeguard.app

# -----------------------------------------------------------------------------
# Stripe (subscriptions + Stripe Connect for CPA referrals)
# -----------------------------------------------------------------------------

# Stripe secret key. SERVER-ONLY.
# string | required | Stripe Dashboard → Developers → API keys | sk_test_... or sk_live_...
STRIPE_SECRET_KEY=

# Stripe webhook signing secret used to verify webhook authenticity.
# string | required | Stripe Dashboard → Developers → Webhooks → endpoint | whsec_...
STRIPE_WEBHOOK_SECRET=

# Price IDs for each plan tier (see lib/stripe/plans.ts).
# string | required | Stripe Dashboard → Products → price ID | price_...
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=

# Stripe publishable key for client-side SDK.
# string | required | Stripe Dashboard → API keys | pk_test_... or pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Connect client ID for OAuth-based platform connections.
# string | required for /api/integrations/stripe-connect | Connect settings | ca_...
STRIPE_CONNECT_CLIENT_ID=

# -----------------------------------------------------------------------------
# Inngest (background jobs)
# -----------------------------------------------------------------------------

# Inngest event key for publishing events from API routes.
# string | required | Inngest Dashboard → Manage → Event Keys | abc123...
INNGEST_EVENT_KEY=

# Inngest signing key for verifying inbound function invocations.
# string | required | Inngest Dashboard → Manage → Signing Keys | signkey-...
INNGEST_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting)
# -----------------------------------------------------------------------------

# Upstash REST URL.
# string (URL) | required | console.upstash.com → Redis → REST API | https://xxx.upstash.io
UPSTASH_REDIS_REST_URL=

# Upstash REST token.
# string | required | console.upstash.com → Redis → REST API | AaBb...
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Encryption (OAuth token storage)
# -----------------------------------------------------------------------------

# AES-256-GCM key (32 bytes hex-encoded → 64 chars). Rotate quarterly.
# Generate: `openssl rand -hex 32`
# string (64 hex chars) | required | rotate quarterly | b8f3...c4a1
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------

# Server DSN.
# string (URL) | optional | Sentry → project → Client Keys | https://xxx@sentry.io/123
SENTRY_DSN=

# Public DSN exposed to the browser.
# string (URL) | optional | same value, surfaced to client | https://xxx@sentry.io/123
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token used to upload sourcemaps in CI.
# string | optional | sentry.io → Account → Auth Tokens | sntrys_...
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# PostHog (product analytics + feature flags)
# -----------------------------------------------------------------------------

# Public project API key.
# string | optional | PostHog → Project Settings | phc_...
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingestion host.
# string (URL) | optional | EU users: https://eu.i.posthog.com | https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# OAuth integrations (Phase 2 — Financial OS)
# -----------------------------------------------------------------------------

# PayPal REST API credentials.
# string | optional | developer.paypal.com → My Apps | AYSq...
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Plaid credentials for bank linking (transactions API).
# string | optional | dashboard.plaid.com → Team Settings → Keys | xxx
PLAID_CLIENT_ID=
PLAID_SECRET=

# Plaid environment.
# enum(sandbox|development|production) | optional | start in sandbox | sandbox
PLAID_ENV=sandbox
